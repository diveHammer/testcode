#Requires -Modules GroupPolicy
<#
.SYNOPSIS
    Scans all GPOs in the domain for enabled PowerShell Transcription settings.

.DESCRIPTION
    Iterates through every GPO in the domain (alphabetically), inspects the
    registry-based PowerShell Transcription policy under:
        HKLM\Software\Policies\Microsoft\Windows\PowerShell\Transcription

    Checks the following values:
        - EnableTranscripting
        - EnableInvocationHeader
        - OutputDirectory

    Only GPOs where at least one of these values is ENABLED (set to 1 or a
    non-empty string) are written to the CSV report.
    GPOs with no settings or disabled settings are silently skipped.

.PARAMETER OutputCSV
    Full path for the CSV output file.
    Default: .\GPO_PSTranscription_Report_<timestamp>.csv

.PARAMETER Domain
    Target domain FQDN. Defaults to the current user's domain.

.EXAMPLE
    .\Get-GPOPowerShellTranscription.ps1

.EXAMPLE
    .\Get-GPOPowerShellTranscription.ps1 -OutputCSV "C:\Reports\PSTranscription.csv" -Domain "corp.contoso.com"

.NOTES
    Requires the GroupPolicy PowerShell module (RSAT: Group Policy Management Tools).
    Must be run with an account that has read access to SYSVOL / GPO objects.
#>

[CmdletBinding()]
param (
    [string]$OutputCSV = ".\GPO_PSTranscription_Report_$(Get-Date -Format 'yyyyMMdd_HHmmss').csv",
    [string]$Domain    = $env:USERDNSDOMAIN
)

# ── Colour helpers ────────────────────────────────────────────────────────────
function Write-Status {
    param([string]$GPOName, [string]$Status, [string]$Detail = '')
    $colour = switch ($Status) {
        'Scanning'      { 'Cyan'    }
        'Found'         { 'Green'   }
        'Not Found'     { 'DarkGray'}
        'Error'         { 'Red'     }
        default         { 'White'   }
    }
    $line = "[{0}]  GPO: {1}" -f $Status.PadRight(10), $GPOName
    if ($Detail) { $line += "  |  $Detail" }
    Write-Host $line -ForegroundColor $colour
}

# ── Registry path & value names to inspect ───────────────────────────────────
$RegKey    = 'HKLM\Software\Policies\Microsoft\Windows\PowerShell\Transcription'
$RegValues = @('EnableTranscripting', 'EnableInvocationHeader', 'OutputDirectory')

# ── Accumulator for CSV rows ──────────────────────────────────────────────────
$Results = [System.Collections.Generic.List[PSCustomObject]]::new()

# ── Load all GPOs sorted alphabetically ──────────────────────────────────────
Write-Host "`nConnecting to domain: $Domain" -ForegroundColor Yellow
try {
    $AllGPOs = Get-GPO -All -Domain $Domain | Sort-Object DisplayName
}
catch {
    Write-Host "ERROR: Could not retrieve GPOs. Ensure RSAT (Group Policy) is installed and you have domain access.`n$_" -ForegroundColor Red
    exit 1
}

Write-Host "Found $($AllGPOs.Count) GPO(s). Starting scan...`n" -ForegroundColor Yellow
Write-Host ("{0}  {1,-50}  {2}" -f "Status    ", "GPO Name", "Detail") -ForegroundColor White
Write-Host ("-" * 100) -ForegroundColor DarkGray

foreach ($GPO in $AllGPOs) {
    $GPOName = $GPO.DisplayName
    Write-Status -GPOName $GPOName -Status 'Scanning'

    $FoundAny = $false

    foreach ($ValueName in $RegValues) {
        try {
            # Get-GPRegistryValue throws if the key/value does not exist
            $RegResult = Get-GPRegistryValue `
                -Guid   $GPO.Id `
                -Domain $Domain `
                -Key    $RegKey `
                -ValueName $ValueName `
                -ErrorAction Stop

            $RawValue = $RegResult.Value

            # Determine whether the setting is meaningfully ENABLED
            $IsEnabled = $false
            if ($RegResult.Type -in 'DWord', 'QWord') {
                # Numeric: enabled when value is 1 (or non-zero)
                $IsEnabled = ([int64]$RawValue -ne 0)
            }
            elseif ($RegResult.Type -in 'String', 'ExpandString') {
                # String (e.g. OutputDirectory): enabled when non-empty
                $IsEnabled = (-not [string]::IsNullOrWhiteSpace($RawValue))
            }

            if ($IsEnabled) {
                $FoundAny = $true
                $DisplayValue = $RawValue.ToString()

                Write-Status -GPOName $GPOName -Status 'Found' `
                    -Detail "$ValueName = $DisplayValue"

                $Results.Add([PSCustomObject]@{
                    GPOName   = $GPOName
                    GPOID     = $GPO.Id.ToString()
                    Setting   = $ValueName
                    Value     = $DisplayValue
                    RegKey    = $RegKey
                    Timestamp = (Get-Date -Format 'yyyy-MM-dd HH:mm:ss')
                })
            }
            # If disabled (0 or empty string) → silently skip
        }
        catch [System.ArgumentException] {
            # Value or key simply does not exist in this GPO — expected, skip quietly
        }
        catch {
            # Unexpected error — log to screen but continue
            Write-Status -GPOName $GPOName -Status 'Error' `
                -Detail "[$ValueName] $($_.Exception.Message)"
        }
    }

    if (-not $FoundAny) {
        Write-Status -GPOName $GPOName -Status 'Not Found'
    }
}

Write-Host ("-" * 100) -ForegroundColor DarkGray

# ── Write CSV ─────────────────────────────────────────────────────────────────
if ($Results.Count -gt 0) {
    try {
        $Results | Export-Csv -Path $OutputCSV -NoTypeInformation -Encoding UTF8
        Write-Host "`nScan complete. $($Results.Count) enabled setting(s) found across GPOs." -ForegroundColor Green
        Write-Host "CSV report saved to: $((Resolve-Path $OutputCSV).Path)" -ForegroundColor Green
    }
    catch {
        Write-Host "`nERROR: Could not write CSV to '$OutputCSV'.`n$_" -ForegroundColor Red
    }
}
else {
    Write-Host "`nScan complete. No enabled PowerShell Transcription settings found in any GPO." -ForegroundColor Yellow
    Write-Host "No CSV file created (nothing to report)." -ForegroundColor Yellow
}

Write-Host ""
