#Requires -Modules GroupPolicy
<#
.SYNOPSIS
    Scans all GPOs in the domain for the DownloadRestrictions policy applied to
    Microsoft Edge and/or Google Chrome (Chromium-based browsers).

.DESCRIPTION
    Iterates through every GPO in the domain (alphabetically) and checks the
    DownloadRestrictions registry value for both browsers:

        Microsoft Edge
            HKLM\Software\Policies\Microsoft\Edge
            Value: DownloadRestrictions

        Google Chrome
            HKLM\Software\Policies\Google\Chrome
            Value: DownloadRestrictions

    DownloadRestrictions numeric values and their meaning:
        0  -  No special restrictions
        1  -  BlockDangerousDownloads           (blocks confirmed-dangerous files)
        2  -  BlockPotentiallyDangerousDownloads (blocks dangerous + potentially dangerous, e.g. .exe)
        3  -  BlockAllDownloads                  (blocks all downloads)
        4  -  BlockMaliciousDownloads            (blocks malware; less restrictive than 1)

    Only GPOs where DownloadRestrictions is set to 1, 2, or 3 are written to
    the CSV report. GPOs with value 0, value 4, or no setting are skipped.

    The script prompts interactively for the CSV save path at startup.

    Compatible with Windows PowerShell 3.0 and later (including 4.0, 5.0, 5.1
    and PowerShell 7+). The GroupPolicy module requires Windows PowerShell
    (not PowerShell Core / PS 7) unless RSAT is installed on the target system.

.PARAMETER Domain
    Target domain FQDN. Defaults to the current user's domain.

.PARAMETER IncludeAllRestrictive
    When specified, also includes value 4 (BlockMaliciousDownloads) in the report.

.EXAMPLE
    .\Get-GPODownloadRestrictions.ps1

.EXAMPLE
    .\Get-GPODownloadRestrictions.ps1 -Domain "corp.contoso.com" -IncludeAllRestrictive

.NOTES
    Minimum PowerShell version : 3.0
    Requires RSAT               : Group Policy Management Tools
    Run as                      : Account with GPO read access in the domain

    Reference:
        https://chromeenterprise.google/policies/#DownloadRestrictions
        https://learn.microsoft.com/en-us/deployedge/microsoft-edge-policies#downloadrestrictions

    --- Compatibility fixes applied (vs original draft) ---
    [PS 7.0+] Ternary operator  (? :)           replaced with if/else blocks
    [PS 5.0+] ::new() constructor                replaced with New-Object
    [PS 3.0+] [ordered]@{} inside loop           replaced with New-Object System.Collections.Specialized.OrderedDictionary
    [PS 3.0+] -in operator                       replaced with -contains
    [PS 3.0+] [string]::IsNullOrWhiteSpace()     replaced with -match and .Trim() check
#>

[CmdletBinding()]
param (
    [string]$Domain            = $env:USERDNSDOMAIN,
    [switch]$IncludeAllRestrictive
)

# ─────────────────────────────────────────────────────────────────────────────
# SECTION 1 — Interactive save-path prompt
# ─────────────────────────────────────────────────────────────────────────────
$DefaultTimestamp = Get-Date -Format 'yyyyMMdd_HHmmss'
$DefaultFileName  = "GPO_DownloadRestrictions_Report_$DefaultTimestamp.csv"
$DefaultSavePath  = Join-Path ([Environment]::GetFolderPath('Desktop')) $DefaultFileName

Write-Host ""
Write-Host "=================================================================" -ForegroundColor Cyan
Write-Host "   GPO DownloadRestrictions Scanner - Edge & Chrome              " -ForegroundColor Cyan
Write-Host "=================================================================" -ForegroundColor Cyan
Write-Host ""
Write-Host "  Enter the full path where the CSV report should be saved." -ForegroundColor White
Write-Host "  Press ENTER to accept the default path shown below." -ForegroundColor DarkGray
Write-Host ""
Write-Host "  Default: $DefaultSavePath" -ForegroundColor DarkGray
Write-Host ""

# Keep prompting until the user provides a valid, writable path
$OutputCSV = $null
while ($null -eq $OutputCSV) {

    $RawInput = Read-Host "  Save report to"

    # Accept default if user pressed Enter with no input
    # PS 3.0-safe null/whitespace check (avoids IsNullOrWhiteSpace)
    if (($null -eq $RawInput) -or ($RawInput.Trim() -eq '')) {
        $RawInput = $DefaultSavePath
    }

    # Ensure the path ends with .csv
    if ($RawInput -notmatch '\.csv$') {
        $RawInput = $RawInput.TrimEnd('\', '/') + "\$DefaultFileName"
        Write-Host "  No filename specified - using: $RawInput" -ForegroundColor DarkGray
    }

    # Validate that the parent directory exists (offer to create it if not)
    $ParentDir = Split-Path -Path $RawInput -Parent
    if (-not (Test-Path -Path $ParentDir -PathType Container)) {
        Write-Host ""
        Write-Host "  Directory does not exist: $ParentDir" -ForegroundColor Yellow
        $CreateDir = Read-Host "  Create it now? (Y/N)"
        if ($CreateDir -match '^[Yy]') {
            try {
                New-Item -ItemType Directory -Path $ParentDir -Force | Out-Null
                Write-Host "  Directory created." -ForegroundColor Green
            }
            catch {
                Write-Host "  ERROR: Could not create directory. $_" -ForegroundColor Red
                Write-Host "  Please enter a different path." -ForegroundColor Yellow
                Write-Host ""
                continue
            }
        }
        else {
            Write-Host "  Please enter a different path." -ForegroundColor Yellow
            Write-Host ""
            continue
        }
    }

    # Test write access with a temporary file
    $TestFile = Join-Path $ParentDir "write_test_$DefaultTimestamp.tmp"
    try {
        [System.IO.File]::WriteAllText($TestFile, 'test')
        Remove-Item $TestFile -ErrorAction SilentlyContinue
        $OutputCSV = $RawInput
    }
    catch {
        Write-Host "  ERROR: Cannot write to that location. Check permissions and try again." -ForegroundColor Red
        Write-Host ""
    }
}

Write-Host ""
Write-Host "  Report will be saved to:" -ForegroundColor White
Write-Host "  $OutputCSV" -ForegroundColor Green
Write-Host ""

# ─────────────────────────────────────────────────────────────────────────────
# SECTION 2 — Configuration
# ─────────────────────────────────────────────────────────────────────────────

# DownloadRestrictions numeric value -> policy label
# Standard hashtable — compatible with PS 2.0+
$ValueMap = @{
    0 = 'NoRestrictions'
    1 = 'BlockDangerousDownloads'
    2 = 'BlockPotentiallyDangerousDownloads'
    3 = 'BlockAllDownloads'
    4 = 'BlockMaliciousDownloads'
}

# Values that actively prevent dangerous / .exe downloads
$ReportableValues = @(1, 2, 3)
if ($IncludeAllRestrictive) { $ReportableValues += 4 }

# Browser name -> registry key
# [ordered]@{} requires PS 3.0+; use OrderedDictionary for PS 2.0 safety.
# This script targets PS 3.0+ but the explicit type documents intent clearly.
$Browsers = New-Object System.Collections.Specialized.OrderedDictionary
$Browsers.Add('Microsoft Edge', 'HKLM\Software\Policies\Microsoft\Edge')
$Browsers.Add('Google Chrome',  'HKLM\Software\Policies\Google\Chrome')

$RegValueName = 'DownloadRestrictions'

# ─────────────────────────────────────────────────────────────────────────────
# SECTION 3 — Helper: colour-coded status line
# ─────────────────────────────────────────────────────────────────────────────
function Write-Status {
    param(
        [string]$GPOName,
        [string]$Status,
        [string]$Detail
    )
    # Default value for optional param — compatible with PS 2.0+
    if ($null -eq $Detail) { $Detail = '' }

    $colour = switch ($Status) {
        'Scanning'   { 'Cyan'     }
        'Found'      { 'Green'    }
        'Not Found'  { 'DarkGray' }
        'Error'      { 'Red'      }
        default      { 'White'    }
    }
    $line = "[{0}]  GPO: {1}" -f $Status.PadRight(10), $GPOName
    if ($Detail -ne '') { $line += "  |  $Detail" }
    Write-Host $line -ForegroundColor $colour
}

# ─────────────────────────────────────────────────────────────────────────────
# SECTION 4 — Load GPOs
# ─────────────────────────────────────────────────────────────────────────────
Write-Host "Connecting to domain: $Domain" -ForegroundColor Yellow

try {
    $AllGPOs = Get-GPO -All -Domain $Domain | Sort-Object DisplayName
}
catch {
    Write-Host "ERROR: Could not retrieve GPOs. Ensure RSAT (Group Policy) is installed and you have domain access." -ForegroundColor Red
    Write-Host $_ -ForegroundColor Red
    exit 1
}

Write-Host "Found $($AllGPOs.Count) GPO(s). Starting scan..." -ForegroundColor Yellow
Write-Host ""
Write-Host ("{0,-12}  {1,-55}  {2}" -f "Status", "GPO Name", "Detail") -ForegroundColor White
Write-Host ("-" * 110) -ForegroundColor DarkGray

# ─────────────────────────────────────────────────────────────────────────────
# SECTION 5 — Scan loop
# ─────────────────────────────────────────────────────────────────────────────

# New-Object replaces ::new() — compatible with PS 2.0+
$Results = New-Object System.Collections.Generic.List[PSCustomObject]

foreach ($GPO in $AllGPOs) {
    $GPOName    = $GPO.DisplayName
    $FoundInGPO = $false

    Write-Status -GPOName $GPOName -Status 'Scanning'

    # Per-browser result slots — OrderedDictionary for PS 2.0+ compatibility
    $BrowserResults = New-Object System.Collections.Specialized.OrderedDictionary
    foreach ($BrowserName in $Browsers.Keys) {
        $BrowserResults[$BrowserName] = $null
    }

    foreach ($BrowserName in $Browsers.Keys) {
        $RegKey = $Browsers[$BrowserName]

        try {
            $RegResult = Get-GPRegistryValue `
                -Guid        $GPO.Id `
                -Domain      $Domain `
                -Key         $RegKey `
                -ValueName   $RegValueName `
                -ErrorAction Stop

            $NumericValue = [int]$RegResult.Value

            # -contains replaces -in operator (PS 2.0+ safe)
            if ($ReportableValues -contains $NumericValue) {

                if ($ValueMap.ContainsKey($NumericValue)) {
                    $PolicyLabel = $ValueMap[$NumericValue]
                }
                else {
                    $PolicyLabel = "UnknownValue($NumericValue)"
                }

                $BrowserResults[$BrowserName] = $PolicyLabel
                $FoundInGPO = $true

                Write-Status -GPOName $GPOName -Status 'Found' `
                    -Detail "$BrowserName -> $PolicyLabel (value $NumericValue)"
            }
            # Value 0 or non-reportable -> skip silently
        }
        catch [System.ArgumentException] {
            # Key or value not present in this GPO — expected, continue
        }
        catch {
            Write-Status -GPOName $GPOName -Status 'Error' `
                -Detail "[$BrowserName] $($_.Exception.Message)"
        }
    }

    if ($FoundInGPO) {

        # Resolve Edge value — if/else replaces ternary (? :) operator (PS 7.0+)
        if ($BrowserResults['Microsoft Edge']) {
            $EdgeValue = $BrowserResults['Microsoft Edge']
        }
        else {
            $EdgeValue = 'NotConfigured'
        }

        # Resolve Chrome value
        if ($BrowserResults['Google Chrome']) {
            $ChromeValue = $BrowserResults['Google Chrome']
        }
        else {
            $ChromeValue = 'NotConfigured'
        }

        # Resolve boolean summary columns — -contains replaces -in
        $AllValues = @($BrowserResults['Microsoft Edge'], $BrowserResults['Google Chrome'])

        if ($AllValues -contains 'BlockDangerousDownloads') {
            $HasBlock1 = 'Yes'
        }
        else {
            $HasBlock1 = 'No'
        }

        if ($AllValues -contains 'BlockPotentiallyDangerousDownloads') {
            $HasBlock2 = 'Yes'
        }
        else {
            $HasBlock2 = 'No'
        }

        if ($AllValues -contains 'BlockAllDownloads') {
            $HasBlock3 = 'Yes'
        }
        else {
            $HasBlock3 = 'No'
        }

        $Results.Add([PSCustomObject]@{
            GPOName                                 = $GPOName
            GPOID                                   = $GPO.Id.ToString()
            'Microsoft Edge - DownloadRestrictions' = $EdgeValue
            'Google Chrome - DownloadRestrictions'  = $ChromeValue
            BlockDangerousDownloads                 = $HasBlock1
            BlockPotentiallyDangerousDownloads      = $HasBlock2
            BlockAllDownloads                       = $HasBlock3
            Timestamp                               = (Get-Date -Format 'yyyy-MM-dd HH:mm:ss')
        })
    }
    else {
        Write-Status -GPOName $GPOName -Status 'Not Found'
    }
}

Write-Host ("-" * 110) -ForegroundColor DarkGray

# ─────────────────────────────────────────────────────────────────────────────
# SECTION 6 — Write CSV and summary
# ─────────────────────────────────────────────────────────────────────────────
if ($Results.Count -gt 0) {
    try {
        $Results | Export-Csv -Path $OutputCSV -NoTypeInformation -Encoding UTF8

        Write-Host ""
        Write-Host "Scan complete. $($Results.Count) GPO(s) with reportable DownloadRestrictions found." -ForegroundColor Green
        Write-Host "CSV report saved to: $((Resolve-Path $OutputCSV).Path)" -ForegroundColor Green

        Write-Host ""
        Write-Host "-- Summary -----------------------------------------------------------------------" -ForegroundColor Yellow
        $Results | Format-Table -AutoSize `
            GPOName,
            'Microsoft Edge - DownloadRestrictions',
            'Google Chrome - DownloadRestrictions',
            BlockDangerousDownloads,
            BlockPotentiallyDangerousDownloads,
            BlockAllDownloads
    }
    catch {
        Write-Host ""
        Write-Host "ERROR: Could not write CSV to '$OutputCSV'." -ForegroundColor Red
        Write-Host $_ -ForegroundColor Red
    }
}
else {
    Write-Host ""
    Write-Host "Scan complete. No GPOs with DownloadRestrictions set to BlockDangerousDownloads," -ForegroundColor Yellow
    Write-Host "BlockPotentiallyDangerousDownloads, or BlockAllDownloads were found." -ForegroundColor Yellow
    Write-Host "No CSV file created (nothing to report)." -ForegroundColor Yellow
}

Write-Host ""
