<#
.SYNOPSIS
    Scans all GPOs for configured Power Options under:
    COMPUTER CONFIGURATION\PREFERENCES\CONTROL PANEL SETTINGS\POWER OPTIONS

    Outputs:
        - GPO Name
        - Section (Computer)
        - Power Plan (Balanced, High Performance, etc.)
        - Saved to CSV

#>

Import-Module GroupPolicy

# Prompt for save path
$savePath = Read-Host "Enter path to save report (default: C:\Temp)"

if ([string]::IsNullOrWhiteSpace($savePath)) {
    $savePath = "C:\Temp"
}

if (-not (Test-Path $savePath)) {
    Write-Host "Path does not exist. Creating $savePath..." -ForegroundColor Yellow
    New-Item -ItemType Directory -Path $savePath | Out-Null
}

$csvFile = Join-Path $savePath "GPO_PowerSettingsReport.csv"

$results = @()

Write-Host "`nScanning GPOs..." -ForegroundColor Cyan

# Get all GPOs alphabetically
$gpos = Get-GPO -All | Sort-Object DisplayName

foreach ($gpo in $gpos) {

    Write-Host "Processing: $($gpo.DisplayName)" -ForegroundColor Yellow

    # Get XML report
    $xml = Get-GPOReport -Guid $gpo.Id -ReportType Xml
    $gpoXml = [xml]$xml

    # Navigate to Computer Preferences → Control Panel Settings → Power Options
    $powerOptions = $gpoXml.GPO.Computer.ExtensionData.Extension |
        Where-Object { $_.Name -eq "PowerOptions" }

    if ($powerOptions) {

        foreach ($entry in $powerOptions.PowerScheme) {

            # Extract the power plan name
            $planName = $entry.Name

            if ($planName) {
                $results += [pscustomobject]@{
                    GPOName   = $gpo.DisplayName
                    Section   = "Computer"
                    PowerPlan = $planName
                }
            }
        }
    }
}

# Output to screen
$results | Format-Table -AutoSize

# Export to CSV
$results | Export-Csv -Path $csvFile -NoTypeInformation -Encoding UTF8

Write-Host "`nReport saved to: $csvFile" -ForegroundColor Green
